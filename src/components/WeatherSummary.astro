---
import type { CurrentWeather, Location } from "../lib/types";

interface Props {
  location: Location;
  current: CurrentWeather;
}

const { location, current } = Astro.props;
---

<section class="bg-[var(--color-brand)] text-white">
  <div class="mx-auto max-w-3xl px-5 py-6 sm:py-8">
    <div class="flex items-center justify-between gap-4">
      <div>
        <h1 class="font-[family-name:var(--font-display)] text-2xl font-bold tracking-tight sm:text-3xl">
          CanIDo<span class="text-[var(--color-status-green)]">.</span>today
        </h1>
        <p class="mt-1 text-sm text-white/70">
          Can you do that outdoor project today?
        </p>
      </div>
      <button
        type="button"
        class="rounded-full border border-white/20 bg-white/5 px-3 py-1.5 text-xs font-medium text-white/80 hover:bg-white/10"
      >
        Change
      </button>
    </div>

    <div class="mt-5 flex flex-wrap items-baseline gap-x-3 gap-y-1">
      <span class="text-sm font-medium text-white/80">
        📍 {location.city}, {location.state}
      </span>
      <span class="text-xs text-white/50">
        {location.lat.toFixed(2)}, {location.lon.toFixed(2)}
      </span>
    </div>

    <div class="mt-4 flex flex-wrap items-baseline gap-x-5 gap-y-2">
      <div class="flex items-baseline gap-2">
        <span class="font-[family-name:var(--font-display)] text-4xl font-bold sm:text-5xl">
          {current.temperature}°
        </span>
        <span class="text-sm text-white/70">{current.description}</span>
      </div>
    </div>

    <dl class="mt-4 grid grid-cols-2 gap-x-4 gap-y-2 text-sm sm:grid-cols-4">
      <div>
        <dt class="text-xs uppercase tracking-wide text-white/50">Humidity</dt>
        <dd class="font-medium">{current.humidity}%</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-white/50">Wind</dt>
        <dd class="font-medium">{current.windSpeed} mph</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-white/50">Dew point</dt>
        <dd class="font-medium">{current.dewPoint}°</dd>
      </div>
      <div>
        <dt class="text-xs uppercase tracking-wide text-white/50">Rain</dt>
        <dd class="font-medium">
          {current.hoursUntilRain === null ? "—" : `${current.hoursUntilRain}h away`}
        </dd>
      </div>
    </dl>
  </div>
</section>
